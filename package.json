{
  "name": "@workspacejson/spec",
  "version": "0.2.1",
  "description": "JSON Schema and TypeScript types for .agents/agents.workspace.json",
  "license": "Apache-2.0",
  "author": "workspace-json contributors",
  "homepage": "https://www.workspacejson.dev",
  "keywords": [
    "workspace.json",
    "agents.workspace.json",
    "ai-agents",
    "ai-coding-agents",
    "codebase-intelligence",
    "open-standard",
    "json-schema",
    "developer-tools",
    "aaif",
    "agents-audit",
    "AGENTS.md",
    "claude-code",
    "cursor",
    "goose",
    "cline"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workspace-json/spec.git"
  },
  "bugs": {
    "url": "https://github.com/workspace-json/spec/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": "./schema/v1.json"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/generate-types.js",
    "conformance": "node conformance/runner.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^14.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
