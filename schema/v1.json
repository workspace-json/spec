{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workspacejson.dev/schemas/agents.workspace.v1.json",
  "title": "agents.workspace.json",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
