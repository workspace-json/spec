{
  "name": "agents-audit",
  "version": "0.1.0",
  "description": "Audit tool for AGENTS.md hygiene - reads agents.workspace.json for richer findings",
  "license": "Apache-2.0",
  "author": "workspace-json contributors",
  "homepage": "https://workspacejson.dev/audit/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workspace-json/agents-audit.git"
  },
  "bugs": {
    "url": "https://github.com/workspace-json/agents-audit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "AGENTS.md",
    "workspace.json",
    "ai-agents",
    "audit",
    "lint",
    "cli",
    "developer-tools",
    "aaif"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "bin": {
    "agents-audit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@workspacejson/rules": "workspace:*",
    "@inquirer/core": "^9.0.0",
    "boxen": "^7.1.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dedent": "^1.5.3",
    "ora": "^8.0.1",
    "picocolors": "^1.0.1",
    "terminal-link": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
