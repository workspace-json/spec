{
  "name": "@workspacejson/rules",
  "version": "0.1.1",
  "description": "Rule engine for auditing AGENTS.md hygiene using agents.workspace.json",
  "license": "Apache-2.0",
  "author": "workspace-json contributors",
  "homepage": "https://workspacejson.dev/audit/",
  "keywords": [
    "agents-audit",
    "workspace-json",
    "rule-engine",
    "AGENTS.md",
    "ai-agents",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workspace-json/agents-audit.git",
    "directory": "packages/rules"
  },
  "bugs": {
    "url": "https://github.com/workspace-json/agents-audit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspacejson/spec": "workspace:*",
    "ajv": "^8.16.0",
    "dedent": "^1.5.3",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "remark": "^15.0.0",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.25.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
